# ============================================================
# AJ DIGITAL OS — Environment Template
# Copy to .env and fill in values.
# ============================================================

# Runtime
AJ_OS_ENV=development
HERMES_STATUS_PORT=7420
HERMES_BIND_HOST=127.0.0.1
# Set HERMES_BIND_HOST=0.0.0.0 in production to accept external traffic
ACTIVE_MODEL_PROVIDER=ollama
ENABLED_MODEL_PROVIDERS=ollama
MEMORY_ENABLED=true

# AI / LLM Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
NANO_BANANA_API_KEY=

# Sanity CMS
SANITY_API_TOKEN=
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=

# n8n
N8N_MCP_TOKEN=
N8N_BASE_URL=
N8N_WEBHOOK_URL=

# Local Model Endpoints
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Supabase (Control Layer — clients, missions, mission_runs)
# Use SERVICE ROLE key for server-side — RLS policies require service_role for writes
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Neon (Data Layer — execution runs, steps, observations, failures)
NEON_DATABASE_URL=

# Cloudflare R2 (Asset Storage — mission artifacts, result envelopes)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Stripe (Payments / SaaS Onboarding)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# App Base URL (used for Stripe checkout redirect URLs)
APP_BASE_URL=http://localhost:5173

# Hermes Notifications — Webhook (set ONE of these; first found wins)
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
# N8N_WEBHOOK_URL=

# Slack App Credentials
SLACK_APP_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_VERIFICATION_TOKEN=

# ============================================================
# Ops Stack (Docker Compose)
# ============================================================

# Ports
OPENWEBUI_PORT=3001
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
OTEL_PORT=4317

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-now

# Hermes OpenAI-compatible API (consumed by Open WebUI)
HERMES_API_BASE_URL=http://host.docker.internal:8642/v1
HERMES_API_KEY=change-me

# Manual local services (not Dockerized)
OPENCLAW_URL=http://127.0.0.1:18789
HERMES_DASHBOARD_URL=http://127.0.0.1:9119

# Telegram Local Control Plane
# Required for control-plane:start command
AJ_TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
AJ_ALLOWED_TELEGRAM_USER_IDS=123456789,987654321
AJ_ALLOWED_TELEGRAM_CHAT_IDS=
AJ_CONTROL_PLANE_POLL_INTERVAL_MS=1000
