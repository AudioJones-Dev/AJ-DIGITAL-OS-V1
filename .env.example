# ============================================================
# AJ DIGITAL OS — Environment Template
# Copy to .env and fill in values.
# ============================================================

# Runtime
AJ_OS_ENV=development
ACTIVE_MODEL_PROVIDER=ollama
ENABLED_MODEL_PROVIDERS=ollama
MEMORY_ENABLED=true

# AI / LLM Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
NANO_BANANA_API_KEY=

# Sanity CMS
SANITY_API_TOKEN=
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# n8n
N8N_MCP_TOKEN=
N8N_BASE_URL=
N8N_WEBHOOK_URL=

# Local Model Endpoints
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Supabase (Control Layer — clients, missions, mission_runs)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Neon (Data Layer — execution runs, steps, observations, failures)
NEON_DATABASE_URL=

# Cloudflare R2 (Asset Storage — mission artifacts, result envelopes)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Hermes Notifications — Webhook (set ONE of these; first found wins)
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
# N8N_WEBHOOK_URL=

# Slack App Credentials
SLACK_APP_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_VERIFICATION_TOKEN=
