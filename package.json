{
  "name": "aj-digital-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "aj-digital-os": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/run-tsc.cjs",
    "typecheck": "node scripts/run-tsc.cjs --noEmit",
    "smoke:ollama-provider": "npm run build && node dist/providers/ollama.provider.smoke.js",
    "cli": "node dist/cli.js",
    "release:check": "node dist/cli.js healthcheck --json",
    "start:staging": "npm run build && npm run release:check && node dist/cli.js operator-console --watch",
    "assistant:setup": "npm run build && node dist/cli.js assistant-setup",
    "assistant:doctor": "node dist/cli.js assistant-doctor",
    "assistant:start": "node dist/cli.js assistant-start",
    "assistant:history": "node dist/cli.js assistant-history",
    "assistant:shell": "node dist/cli.js assistant-shell",
    "conversation:history": "node dist/cli.js conversation-history",
    "conversation:thread": "node dist/cli.js conversation-thread",
    "memory:index": "node dist/cli.js memory-index",
    "memory:search": "node dist/cli.js memory-search",
    "memory:stats": "node dist/cli.js memory-stats",
    "ui:start": "npm run build && node dist/cli.js ui-start",
    "deliverables": "node dist/cli.js deliverables",
    "deliverables:pending": "node dist/cli.js list-pending-deliverables",
    "deliverables:submit": "node dist/cli.js submit-for-approval",
    "deliverables:approve": "node dist/cli.js approve-deliverable",
    "deliverables:publish": "node dist/cli.js publish-deliverable",
    "tool-registry": "node dist/cli.js tool-registry",
    "integration-profiles": "node dist/cli.js integration-profiles",
    "model-profiles": "node dist/cli.js model-profiles",
    "cli:assistant": "npm run cli -- assistant",
    "cli:deliverables": "npm run cli -- deliverables",
    "cli:tool-registry": "npm run cli -- tool-registry",
    "cli:integration-profiles": "npm run cli -- integration-profiles",
    "cli:model-profiles": "npm run cli -- model-profiles",
    "cli:help": "npm run cli -- help",
    "cli:dashboard": "npm run cli -- dashboard",
    "cli:healthcheck": "npm run cli -- healthcheck",
    "cli:ollama-probe": "npm run cli -- ollama-probe",
    "cli:console": "npm run cli -- operator-console",
    "cli:pending": "npm run cli -- list-pending-approvals",
    "cli:approved": "npm run cli -- list-approved-runs",
    "cli:failed": "npm run cli -- list-failed-runs",
    "cli:executed": "npm run cli -- list-executed-runs",
    "cli:track": "npm run cli -- track-run",
    "cli:summary": "npm run cli -- run-summary",
    "cli:events": "npm run cli -- run-events",
    "cli:approve": "npm run cli -- approve-run",
    "cli:execute": "npm run cli -- execute-run",
    "cli:resume": "npm run cli -- resume-run",
    "validate:supabase-schema": "npm run build && node --import ./dist/env.js dist/scripts/validate-supabase-schema.js",
    "validate:production": "npm run build && node --import ./dist/env.js dist/scripts/validate-production-ready.js",
    "start:production-local": "npm run validate:production && node dist/server.js",
    "link:local": "npm run build && npm link",
    "start:full": "npm run build && node dist/server.js"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "playwright": "^1.59.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "pg": "^8.20.0",
    "typescript": "^5.8.3"
  }
}
