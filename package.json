{
  "name": "aj-digital-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "aj-digital-os": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "cli": "node dist/cli.js",
    "cli:help": "npm run cli -- help",
    "cli:dashboard": "npm run cli -- dashboard",
    "cli:console": "npm run cli -- operator-console",
    "cli:pending": "npm run cli -- list-pending-approvals",
    "cli:approved": "npm run cli -- list-approved-runs",
    "cli:failed": "npm run cli -- list-failed-runs",
    "cli:executed": "npm run cli -- list-executed-runs",
    "cli:track": "npm run cli -- track-run",
    "cli:summary": "npm run cli -- run-summary",
    "cli:events": "npm run cli -- run-events",
    "cli:approve": "npm run cli -- approve-run",
    "cli:execute": "npm run cli -- execute-run",
    "cli:resume": "npm run cli -- resume-run",
    "control-plane:start": "node --import ./dist/env.js dist/control-plane/index.js",
    "link:local": "npm run build && npm link",
    "smoke": "node dist/scripts/smoke-cli.js",
    "release:check": "npm run typecheck && npm test && npm run build && npm run smoke && npm pack --dry-run",
    "validate:crm-migration": "npm run build && node dist/scripts/validate-crm-migration.js",
    "test": "vitest run",
    "test:crm-rls": "vitest run tests/db/crm-rls.integration.test.ts tests/db/postgres-crm-store.integration.test.ts",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "playwright": "^1.59.1",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.8",
    "pg": "^8.22.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "axios": "^1.16.0"
  }
}
