# ── Environment files ─────────────────────────────────────────
.env
env/.env
*.tsbuildinfo
*.log

# ── Build / dependency output ─────────────────────────────────
node_modules/
dist/
.npm-cache/
backups/
logs/
dashboard/.next/
dashboard/.env.local

# ── Cryptographic material ────────────────────────────────────
*.key
*.pem
*.p12
*.pfx

# ── Runtime / generated state (regenerated locally, never commit) ──
# data/ tree holds local file-backed stores; .gitkeep markers and
# tracked workflow definitions are preserved.
data/**
!data/**/
!data/**/.gitkeep
!data/n8n-workflows/**

# memory/ holds the runtime memory store; MEMORY.md is the live root index
# read by src/memory/memory-index.ts and must remain tracked.
memory/**
!memory/**/
!memory/**/.gitkeep
!memory/MEMORY.md

# Session captures and browser-export scratch outputs
output/
sessions/

# runtime/ — policies are infra-as-code (tracked); everything else is generated.
runtime/cache/
runtime/control-runs.json
runtime/dag/
runtime/events/
runtime/idempotency/
runtime/observability/

# ── Local tool / CLI caches ───────────────────────────────────
.tools/
supabase/.temp/

# ── IDE / editor configs (do not commit personal MCP / launch files) ──
.vscode/
.idea/

# ── Agent / AI tool config directories (local-only, never committed) ──
.adal/
.agents/
.augment/
.bob/
.claude/
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
.goose/
.iflow/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.vibe/
.windsurf/
.zencoder/
